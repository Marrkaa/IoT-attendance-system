@startuml IoT_Attendance_MVC_ClassDiagram

skinparam classAttributeIconSize 0
skinparam defaultFontName Arial
skinparam defaultFontSize 10
skinparam backgroundColor #FFFFFF

skinparam class {
    BackgroundColor #FFE680
    BorderColor #D4A800
    HeaderBackgroundColor #FFC800
    HeaderFontColor #000000
    FontColor #000000
    ArrowColor #555555
}

skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #CCC
}

title IoT Attendance System — UML klasių diagrama (MVC)\nMartynas Dmitrovskis, KTU

' =============================================
' NAVIGATION CONTROLLERS (centras)
' =============================================

class NavigationController {
    operations
    ..
    +redirectToLogin()
    +redirectToRegister()
    +redirectToDashboard()
    +checkUserRole()
    +redirectUserRole()
}

class AdminNavigationController {
    operations
    ..
    +checkUserRole()
    +redirectToUserManagement()
    +redirectToRoomManagement()
    +redirectToLectureManagement()
    +redirectToScheduleManagement()
    +redirectToRouterStatus()
    +redirectToRadiusConfig()
    +redirectToUserProfile()
}

class LecturerNavigationController {
    operations
    ..
    +checkUserRole()
    +redirectToAttendance()
    +redirectToStatistics()
    +redirectToReports()
    +redirectToUserProfile()
}

class StudentNavigationController {
    operations
    ..
    +checkUserRole()
    +redirectToLectures()
    +redirectToHistory()
    +redirectToDevices()
    +redirectToUserProfile()
}

' =============================================
' AUTH CONTROLLERS + VIEWS
' =============================================

class LoginController {
    operations
    ..
    +login()
    +validateUser()
    +redirectToDashboard()
    +updateView()
}

class LoginView {
    operations
    ..
    +insertInformation()
    +redirectToRegister()
    +redirectToForgotPassword()
    +showErrors()
}

class RegisterController {
    operations
    ..
    +register()
    +validateData()
    +createUser()
    +updateView()
    +redirectToLogin()
}

class RegisterView {
    operations
    ..
    +insertInformation()
    +redirectToLogin()
    +showErrors()
}

class ForgotPasswordController {
    operations
    ..
    +requestPasswordReset()
    +validateEmail()
    +sendResetEmail()
    +updateView()
}

class ForgotPasswordView {
    operations
    ..
    +insertEmail()
    +showConfirmation()
    +showErrors()
}

class UserProfileController {
    operations
    ..
    +fetchUserInfo()
    +updateProfile()
    +changePassword()
    +logout()
    +updateView()
}

class UserProfileView {
    operations
    ..
    +showUserInfo()
    +showEditForm()
    +showErrors()
}

