class StudentDeviceController {
    operations
    ..
    +fetchMyDevices()
    +deleteDevice()
    +updateView()
}

note right of StudentDeviceController
    Studentas negali rankiškai
    registruoti MAC — sistema
    priskiria automatiškai per
    RADIUS prisijungimo metu
end note

class StudentDeviceView {
    operations
    ..
    +showMyDevices()
    +showAutoRegisteredInfo()
    +showErrors()
}

' =============================================
' IoT CONTROLLERS
' =============================================

class IoTNodeController {
    operations
    ..
    +receiveStationDump()
    +receiveWifiEvent()
    +receiveRadiusAuthEvent()
    +autoRegisterStudentDevice()
    +processSignalData()
    +resolveStudentByMac()
    +determineAttendanceStatus()
    +updateNodeLastSeen()
}

note right of IoTNodeController
    receiveRadiusAuthEvent() gauna
    username + MAC iš RADIUS →
    automatiškai sukuria StudentDevice
    įrašą duomenų bazėje
end note

class RadiusAuthController {
    operations
    ..
    +handleAccessRequest()
    +validateCredentials()
    +extractMacAddress()
    +sendAccessAccept()
    +sendAccessReject()
    +forwardAuthEventToBackend()
    +logAuthEvent()
}

note right of RadiusAuthController
    RUTX11 siunčia RADIUS request su:
    Username = studento email
    Calling-Station-Id = MAC adresas
    Po sėkmingo auth → siunčia į
    IoTNodeController
end note

' =============================================
' DATABASE
' =============================================

class Database {
    Users
    Rooms
    IoTNodes
    Lectures
    Schedules
    Enrollments
    AttendanceRecords
    StudentDevices
    RadiusAccounts
    WifiConnectionLogs
    Role
    AttendanceStatus
    NodeStatus
    WifiEventType
}

